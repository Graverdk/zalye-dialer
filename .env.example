# ============================================================
# ZALYE DIALER - Environment Variables
# Kopier denne fil til .env og udfyld dine værdier
# ============================================================

# Server
PORT=3000
APP_URL=https://din-server.com   # URL hvor backend kører (bruges i Pipedrive manifest)

# Relatel
# Hent dit API token på: https://app.relatel.dk/account/authorized_applications
RELATEL_ACCESS_TOKEN=dit_relatel_token_her

# Anthropic Claude (analyse + resumé + handlingspunkter + diarization)
# Hent API key på: https://console.anthropic.com
ANTHROPIC_API_KEY=sk-ant-...

# ElevenLabs Scribe (tale-til-tekst med indbygget speaker diarization)
# Hent API key på: https://elevenlabs.io/app/settings/api-keys
# Pris: ~$0.40 / time lyd (ca. 3 øre per 5-min samtale)
ELEVENLABS_API_KEY=sk-...

# Pipedrive
# Hent API token i Pipedrive: Indstillinger > Personlige indstillinger > API
PIPEDRIVE_API_TOKEN=dit_pipedrive_token_her
PIPEDRIVE_COMPANY_DOMAIN=zalye-sandbox  # dit subdomain på pipedrive.com

# Database (SQLite - sti til databasefilen)
DB_PATH=./data/zalye.db

# Polling interval i sekunder (hvor tit vi tjekker Relatel for nye afsluttede opkald)
POLL_INTERVAL_SECONDS=30
